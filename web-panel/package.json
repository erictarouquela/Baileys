{
  "name": "baileys-web-panel",
  "type": "module",
  "version": "1.0.0",
  "description": "Web-based configuration panel for Baileys WhatsApp connections",
  "main": "lib/server.js",
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(m=>m.cpSync('src/public','lib/public',{recursive:true}))\"",
    "start": "node lib/server.js",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "baileys": "file:..",
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
    "express": "^4.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.1",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.9.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2"
  }
}
